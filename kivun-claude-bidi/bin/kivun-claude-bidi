#!/usr/bin/env node
'use strict';

// Entrypoint for kivun-claude-bidi.
// Exit codes (per HEAVY §10):
//   0  clean
//   2  wrapper module load failure (node-pty native build broken, etc.)
//   5  wrong terminal (detect-terminal rejected)
//
// Allowlist policy: see lib/detect-terminal.js. Konsole + Apple Terminal
// are accepted; iTerm2 and WezTerm are explicitly REJECTED because they
// have working native BiDi engines and the wrapper's RLE/PDF marks would
// be applied on top of the terminal's reordering, mirroring Hebrew. (See
// kivun-terminal-rtl-debug.v2.md §2.5.) On rejection, the launcher should
// have set KIVUN_BIDI_WRAPPER=off and never invoked us; if we got here
// anyway, exit 5 with a clear error rather than producing broken output.

const { detectTerminal } = require('../lib/detect-terminal');
const { checkCapability } = require('../lib/capability-check');

function allowOverride(env) {
  // Escape hatch for CI / development. Skips the terminal-allowlist gate.
  // Use sparingly: bypassing on a native-BiDi terminal will mirror Hebrew.
  return env.KIVUN_BIDI_FORCE === '1';
}

function main() {
  const env = process.env;

  const det = detectTerminal(env);
  if (!det.ok && !allowOverride(env)) {
    process.stderr.write(`kivun-claude-bidi: ${det.reason}\n`);
    process.exit(5);
  }

  checkCapability(env);

  let wrapper;
  try {
    wrapper = require('../lib/wrapper');
  } catch (err) {
    process.stderr.write(
      `kivun-claude-bidi: wrapper module failed to load (${err.code || err.message}).\n` +
      `Set KIVUN_BIDI_WRAPPER=off in your config to fall back to plain claude.\n`,
    );
    process.exit(2);
  }

  wrapper.run(process.argv.slice(2), env);
}

main();
