#!/bin/bash
# Kivun Terminal — macOS dependency installer (postinstall)
# Runs as root after .pkg installation

# Do NOT use set -e — we handle errors per-step so one failure doesn't kill
# the whole install. But DO use pipefail so `cmd | tee -a LOG` doesn't mask
# upstream failures (curl-fails-but-tee-succeeds → we'd chmod+exec an empty
# file and log "installed" without actually installing).
set -o pipefail
LOG_FILE="/tmp/kivun_install.log"
REAL_USER="${SUDO_USER:-$(stat -f '%Su' /dev/console)}"
REAL_HOME=$(dscl . -read "/Users/$REAL_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
REAL_HOME="${REAL_HOME:-/Users/$REAL_USER}"

log() { echo "[$(date '+%H:%M:%S')] $1" | tee -a "$LOG_FILE"; }

# Run command as the real user with proper PATH including Homebrew
run_as_user() {
    sudo -u "$REAL_USER" bash -l -c "$1"
}

log "=== Kivun Terminal macOS Installer ==="
log "User: $REAL_USER | Home: $REAL_HOME"
log "Arch: $(uname -m) | macOS: $(sw_vers -productVersion)"

# --- Xcode Command Line Tools (required for Homebrew & Git) ---
log "Checking Xcode CLT..."
CLT_PATH=$(xcode-select -p 2>&1) || true
log "xcode-select -p: '$CLT_PATH' (exit: $?)"

if ! xcode-select -p &>/dev/null; then
    log "CLT not installed — attempting non-interactive install via softwareupdate"
    touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress

    log "Running: softwareupdate -l (listing available updates)..."
    SWUPDATE_OUTPUT=$(softwareupdate -l 2>&1) || true
    log "softwareupdate -l output:"
    echo "$SWUPDATE_OUTPUT" >> "$LOG_FILE"

    CLT_LABEL=$(echo "$SWUPDATE_OUTPUT" | grep 'Label:.*Command Line Tools' | sed 's/.*Label: //' | sed 's/[[:space:]]*$//' | head -1)
    log "Parsed CLT label: '$CLT_LABEL'"

    if [ -n "$CLT_LABEL" ]; then
        log "Installing: $CLT_LABEL (this may take 5-10 minutes)..."
        softwareupdate -i "$CLT_LABEL" 2>&1 | tee -a "$LOG_FILE"
        SW_EXIT=$?
        log "softwareupdate -i exit code: $SW_EXIT"
    else
        log "WARNING: No CLT package found in Software Update catalog"
        log "Attempting xcode-select --install as fallback..."
        xcode-select --install 2>&1 | tee -a "$LOG_FILE" || true
    fi

    rm -f /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress

    if xcode-select -p &>/dev/null; then
        log "Xcode CLT installed at: $(xcode-select -p)"
    else
        log "WARNING: Xcode CLT still not detected after install attempt"
    fi
else
    log "Xcode CLT already installed at: $CLT_PATH"
fi

# --- Homebrew ---
log "Checking Homebrew..."
BREW_PATH=$(run_as_user "command -v brew" 2>&1) || true
log "brew path: '$BREW_PATH'"

if ! run_as_user "command -v brew" &>/dev/null; then
    log "Homebrew not found — installing..."

    # Pre-checks
    log "Pre-checks before Homebrew install:"
    log "  curl: $(which curl 2>&1)"
    log "  git: $(run_as_user 'command -v git' 2>&1 || echo 'not found')"
    log "  xcode-select -p: $(xcode-select -p 2>&1 || echo 'not installed')"
    log "  Running as user: $REAL_USER"
    log "  User HOME: $REAL_HOME"
    log "  User shell: $(dscl . -read /Users/$REAL_USER UserShell 2>/dev/null | awk '{print $2}' || echo 'unknown')"

    # The Homebrew installer checks `sudo -n` BEFORE doing anything else.
    # In a .pkg postinstall context there is no TTY, so sudo -n always fails
    # ("Need sudo access on macOS"). Fix: temporarily grant passwordless sudo.
    log "Granting narrow temporary sudo for Homebrew's pre-flight check..."
    SUDOERS_TMP="/etc/sudoers.d/kivun-brew-temp"

    # Proactive sweep: a previous install killed with SIGKILL may have left
    # this file in place, persisting the narrow entry indefinitely.
    if [ -f "$SUDOERS_TMP" ]; then
        log "  WARNING: stale $SUDOERS_TMP found from a prior install — removing"
        rm -f "$SUDOERS_TMP"
    fi

    # Primary cleanup: trap on all signals we can catch. SIGKILL can't be
    # trapped, so this is best-effort.
    trap 'rm -f "$SUDOERS_TMP"; log "Cleaned up temporary sudo file"' EXIT ERR INT TERM HUP

    # Belt-and-braces: schedule a removal via `at` 15 min from now so the
    # file cannot persist across a reboot even if the trap never fires.
    if command -v at >/dev/null 2>&1; then
        echo "rm -f $SUDOERS_TMP" | at now + 15 minutes 2>/dev/null \
            && log "  Scheduled fallback cleanup via 'at' in 15 min" \
            || log "  (at daemon unavailable — relying on trap + next-install sweep)"
    fi

    # NARROW scope: grant passwordless sudo for ONLY /usr/bin/true. This
    # is just enough for Homebrew's `sudo -v` / `sudo -n true` pre-flight
    # check to succeed — which is the only thing that blocked us in the
    # non-TTY .pkg context. It is NOT full NOPASSWD:ALL. The real
    # filesystem operations (chown on BREW_PREFIX) are done ABOVE as root
    # in the postinstall script itself, pre-emptively, so Homebrew never
    # needs to re-invoke sudo for them. If Homebrew ever DOES need real
    # sudo during install (e.g. pre-chown didn't work), it will fail
    # loudly here rather than silently receiving root privileges. That
    # failure is the tell that this scope needs to expand.
    echo "$REAL_USER ALL=(ALL) NOPASSWD: /usr/bin/true" > "$SUDOERS_TMP"
    chmod 0440 "$SUDOERS_TMP"
    log "  Created $SUDOERS_TMP (scope: /usr/bin/true only)"

    # Also pre-create Homebrew prefix directory
    if [[ $(uname -m) == "arm64" ]]; then
        BREW_PREFIX="/opt/homebrew"
    else
        BREW_PREFIX="/usr/local/Homebrew"
    fi
    mkdir -p "$BREW_PREFIX" 2>/dev/null || true
    chown -R "$REAL_USER:admin" "$BREW_PREFIX" 2>/dev/null || true
    log "  $BREW_PREFIX owner: $(ls -ld "$BREW_PREFIX" 2>&1)"

    log "Running Homebrew installer (NONINTERACTIVE=1)..."
    BREW_OUTPUT=$(run_as_user 'NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"' 2>&1)
    BREW_EXIT=$?

    # Remove temporary sudo access immediately
    rm -f "$SUDOERS_TMP"
    trap - EXIT ERR INT TERM
    log "  Removed $SUDOERS_TMP"

    log "Homebrew installer exit code: $BREW_EXIT"
    log "Homebrew installer output:"
    echo "$BREW_OUTPUT" >> "$LOG_FILE"

    # Log last 20 lines to console too
    echo "$BREW_OUTPUT" | tail -20 | while IFS= read -r line; do log "  brew: $line"; done

    if [ $BREW_EXIT -eq 0 ]; then
        # Add brew to shell profile. Intel usually gets /usr/local/bin on
        # PATH by default, but `/bin/sh -l` and certain minimal contexts
        # don't — so add shellenv for both archs.
        if [[ $(uname -m) == "arm64" ]]; then
            BREW_BIN="/opt/homebrew/bin/brew"
        else
            BREW_BIN="/usr/local/bin/brew"
        fi
        if ! grep -q "brew shellenv" "$REAL_HOME/.zprofile" 2>/dev/null; then
            run_as_user "echo 'eval \"\$($BREW_BIN shellenv)\"' >> ~/.zprofile"
            log "Added brew shellenv to .zprofile ($BREW_BIN)"
        fi
        log "Homebrew installed successfully"
    else
        log "ERROR: Homebrew installation failed (exit code: $BREW_EXIT)"
        log "Check full output in $LOG_FILE for details"
    fi
else
    BREW_VER=$(run_as_user 'brew --version' 2>/dev/null | head -1)
    log "Homebrew already installed: $BREW_VER"
fi

# --- Node.js ---
if ! run_as_user "command -v node" &>/dev/null; then
    log "Installing Node.js..."
    if run_as_user "brew install node"; then
        log "Node.js $(run_as_user 'node --version' 2>/dev/null) installed"
    else
        log "ERROR: Node.js installation failed"
    fi
else
    log "Node.js $(run_as_user 'node --version' 2>/dev/null) already installed — skipping"
fi

# --- Git ---
if ! run_as_user "command -v git" &>/dev/null; then
    log "Installing Git..."
    if run_as_user "brew install git"; then
        log "Git installed"
    else
        log "ERROR: Git installation failed"
    fi
else
    log "Git already installed — skipping"
fi

# --- Claude Code ---
if ! run_as_user "command -v claude" &>/dev/null; then
    log "Installing Claude Code via Anthropic native installer..."
    CLAUDE_INSTALL_SCRIPT="/tmp/claude-install.sh"
    if curl -fsSL -o "$CLAUDE_INSTALL_SCRIPT" "https://claude.ai/install.sh" 2>&1 | tee -a "$LOG_FILE"; then
        chmod +x "$CLAUDE_INSTALL_SCRIPT"
        if run_as_user "bash '$CLAUDE_INSTALL_SCRIPT'"; then
            log "Claude Code installed"
        else
            log "ERROR: Claude Code installation failed"
        fi
        rm -f "$CLAUDE_INSTALL_SCRIPT"
    else
        log "ERROR: Failed to download Claude Code installer"
    fi
else
    log "Claude Code already installed — skipping"
fi

# --- WezTerm (auto-installed for correct macOS RTL) ---
# WezTerm is the only macOS terminal in our matrix that renders Hebrew
# correctly out of the box. Apple Terminal lacks BiDi paragraph
# reordering, and iTerm2 3.6.x has a broken BiDi engine that mirrors
# Hebrew. WezTerm has native BiDi on by default. The .pkg installs it
# via brew --cask so users don't have to do it manually.
# Reference: kivun-terminal-rtl-debug.v2.md §2.2, §3, §7.
log "Checking WezTerm..."
if [ -d "/Applications/WezTerm.app" ] || run_as_user "command -v wezterm" &>/dev/null; then
    log "WezTerm already installed — skipping"
else
    log "Installing WezTerm via Homebrew (one-time, ~30-60s)..."
    if run_as_user "brew install --cask wezterm" 2>&1 | tee -a "$LOG_FILE" >/dev/null; then
        log "WezTerm installed at /Applications/WezTerm.app"
    else
        log "WARNING: WezTerm install failed — RTL rendering will be limited."
        log "  Recover with:  brew install --cask wezterm"
    fi
fi

# --- Statusline (with SHA256 integrity check) ---
STATUSLINE_DIR="/usr/local/share/kivun-terminal"
STATUSLINE_SRC="$(dirname "$0")/statusline.mjs"
STATUSLINE_SHA="$(dirname "$0")/statusline.mjs.sha256"
log "Installing statusline..."
mkdir -p "$STATUSLINE_DIR" 2>/dev/null || true
if [ -f "$STATUSLINE_SRC" ]; then
    if [ -f "$STATUSLINE_SHA" ]; then
        EXPECTED=$(awk '{print $1}' "$STATUSLINE_SHA")
        ACTUAL=$(shasum -a 256 "$STATUSLINE_SRC" 2>/dev/null | awk '{print $1}')
        if [ -n "$EXPECTED" ] && [ "$EXPECTED" != "$ACTUAL" ]; then
            log "ERROR: statusline.mjs SHA256 mismatch — expected $EXPECTED, got $ACTUAL. Skipping install."
        else
            cp "$STATUSLINE_SRC" "$STATUSLINE_DIR/statusline.mjs"
            chmod 644 "$STATUSLINE_DIR/statusline.mjs"
            log "Statusline copied to $STATUSLINE_DIR/statusline.mjs (SHA256 verified)"
        fi
    else
        cp "$STATUSLINE_SRC" "$STATUSLINE_DIR/statusline.mjs"
        chmod 644 "$STATUSLINE_DIR/statusline.mjs"
        log "Statusline copied to $STATUSLINE_DIR/statusline.mjs (no SHA file shipped)"
    fi
else
    log "WARNING: statusline.mjs not found in package — skipping"
fi

# --- Language map (shared with Linux launcher) ---
LANG_MAP_SRC="$(dirname "$0")/languages.sh"
if [ -f "$LANG_MAP_SRC" ]; then
    cp "$LANG_MAP_SRC" "$STATUSLINE_DIR/languages.sh"
    chmod 644 "$STATUSLINE_DIR/languages.sh"
    log "Language map copied to $STATUSLINE_DIR/languages.sh"
else
    log "WARNING: languages.sh not found in package — skipping"
fi

# --- WezTerm config (Kivun-bundled — enables BiDi + light-blue theme) ---
# WezTerm 20240127+ supports BiDi but ships with bidi_enabled=false. Without
# this config the v1.2.2 Mac install opened a default-themed (dark) WezTerm
# window and rendered Hebrew LTR-mirrored. Loaded by the launcher via
# `wezterm --config-file`, which leaves the user's own ~/.config/wezterm/
# wezterm.lua untouched. v1.2.3.
WEZTERM_LUA_SRC="$(dirname "$0")/wezterm.lua"
if [ -f "$WEZTERM_LUA_SRC" ]; then
    cp "$WEZTERM_LUA_SRC" "$STATUSLINE_DIR/wezterm.lua"
    chmod 644 "$STATUSLINE_DIR/wezterm.lua"
    log "WezTerm config copied to $STATUSLINE_DIR/wezterm.lua"
else
    log "WARNING: wezterm.lua not found in package — WezTerm will use default config (BiDi off, dark theme)"
fi

# --- Uninstaller ---
UNINSTALL_SRC="$(dirname "$0")/uninstall.sh"
if [ -f "$UNINSTALL_SRC" ]; then
    cp "$UNINSTALL_SRC" "$STATUSLINE_DIR/uninstall.sh"
    chmod 755 "$STATUSLINE_DIR/uninstall.sh"
    log "Uninstaller copied to $STATUSLINE_DIR/uninstall.sh — run it to remove Kivun Terminal"
fi

# --- BiDi wrapper (kivun-claude-bidi) ---
# Mirrors the Windows installer: ship source under STATUSLINE_DIR and run
# `npm install --production` once so first launch is instant. Run as the
# real user (not root) so node-pty's native build picks up that user's
# Homebrew node and lands in a tree the user can write to. Failure is
# non-fatal — the launcher silently falls back to unwrapped `claude`.
WRAPPER_SRC="$(dirname "$0")/kivun-claude-bidi"
WRAPPER_DST="$STATUSLINE_DIR/kivun-claude-bidi"
if [ -d "$WRAPPER_SRC" ]; then
    log "Installing BiDi wrapper to $WRAPPER_DST..."
    rm -rf "$WRAPPER_DST" 2>/dev/null || true
    mkdir -p "$WRAPPER_DST"
    (cd "$WRAPPER_SRC" && tar --exclude=node_modules --exclude=.git -cf - .) \
        | (cd "$WRAPPER_DST" && tar xf -)
    chmod +x "$WRAPPER_DST/bin/kivun-claude-bidi" 2>/dev/null || true
    # Real user must own the tree so `npm install` can write node_modules
    # (and so non-root subsequent launches can read it).
    chown -R "$REAL_USER" "$WRAPPER_DST" 2>/dev/null || true

    # npm install — best effort. If node was just installed via brew above,
    # `command -v node` from a login shell will find it; if it failed, we
    # log and move on (the .command launcher will still try unwrapped claude).
    if run_as_user "command -v npm" &>/dev/null; then
        log "Running npm install --production for wrapper (one-time, ~5-15s)..."
        if run_as_user "cd '$WRAPPER_DST' && npm install --production --no-audit --no-fund" 2>&1 | tee -a "$LOG_FILE"; then
            run_as_user "mkdir -p '$WRAPPER_DST/node_modules' && touch '$WRAPPER_DST/node_modules/.kivun-install-stamp'"
            log "BiDi wrapper installed at $WRAPPER_DST/bin/kivun-claude-bidi"
        else
            log "WARNING: npm install for wrapper failed — launcher will fall back to unwrapped claude"
        fi
    else
        log "WARNING: npm not on user's PATH — skipping wrapper install (launcher will fall back to unwrapped claude)"
    fi
else
    log "WARNING: kivun-claude-bidi source not found in package — skipping wrapper install"
fi

# --- BiDi wrapper self-test ---
# Pipe a known Hebrew+English line through the Injector and check that the
# RLE U+202B byte sequence (0xE2 0x80 0xAB) lands in the output. If it
# does, the wrapper is functional end-to-end on this host. Non-blocking:
# a FAIL is logged but install continues — the launcher's silent fallback
# to unwrapped claude already covers the user-visible regression case.
if [ -f "$WRAPPER_DST/lib/injector.js" ] && run_as_user "command -v node" &>/dev/null; then
    log "Running BiDi self-test..."
    SELFTEST_OUT=$(run_as_user "cd '$WRAPPER_DST' && node" 2>&1 << 'SELFTEST_JS'
const { Injector } = require('./lib/injector');
const i = new Injector();
process.stdout.write(i.write('Hello שלום world\n'));
process.stdout.write(i.end());
SELFTEST_JS
)
    if printf '%s' "$SELFTEST_OUT" | grep -qF "$(printf '\xe2\x80\xab')"; then
        log "BiDi self-test: PASS"
    else
        log "BiDi self-test: FAIL"
        log "  (RTL languages may render as LTR; set KIVUN_BIDI_WRAPPER=off in config to silence)"
        log "  (selftest output snippet: $(printf '%s' "$SELFTEST_OUT" | head -c 200))"
    fi
else
    log "BiDi self-test: SKIP (wrapper not installed or node unavailable)"
fi

# Set CLAUDE_CODE_STATUSLINE in user's shell profile
SHELL_RC="$REAL_HOME/.zshrc"
if [ -f "$REAL_HOME/.bashrc" ] && [ ! -f "$REAL_HOME/.zshrc" ]; then
    SHELL_RC="$REAL_HOME/.bashrc"
fi
# Create shell rc if it doesn't exist
run_as_user "touch '$SHELL_RC'" 2>/dev/null || true
EXPORT_LINE="export CLAUDE_CODE_STATUSLINE=\"$STATUSLINE_DIR/statusline.mjs\""
if ! grep -q "CLAUDE_CODE_STATUSLINE" "$SHELL_RC" 2>/dev/null; then
    run_as_user "echo '' >> '$SHELL_RC' && echo '# Kivun Terminal statusline' >> '$SHELL_RC' && echo '$EXPORT_LINE' >> '$SHELL_RC'"
    log "CLAUDE_CODE_STATUSLINE added to $SHELL_RC"
else
    log "CLAUDE_CODE_STATUSLINE already in $SHELL_RC — skipping"
fi

# Configure statusline in Claude Code settings.json
CONFIGURE_SCRIPT="$(dirname "$0")/configure-statusline.js"
if [ -f "$CONFIGURE_SCRIPT" ]; then
    log "Configuring statusline in Claude Code settings..."
    run_as_user "node '$CONFIGURE_SCRIPT' '$STATUSLINE_DIR/statusline.mjs'" 2>/dev/null
    if [ $? -eq 0 ]; then
        log "Statusline configured in Claude Code settings"
    else
        log "WARNING: Could not configure statusline in settings"
    fi
else
    log "WARNING: configure-statusline.js not found in package"
fi

# --- Configuration File ---
log "Creating configuration file..."
CONFIG_DIR="$REAL_HOME/Library/Application Support/Kivun-Terminal"
CONFIG_FILE="$CONFIG_DIR/config.txt"
run_as_user "mkdir -p '$CONFIG_DIR'" 2>/dev/null || true
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" << 'CONFIG'
# Kivun Terminal Configuration (macOS)
# Schema is shared with the Windows (WSL) build where applicable.

# =================================================================
# CLAUDE RESPONSE LANGUAGE
# =================================================================
# Options: english, hebrew, arabic, persian, urdu, kurdish, pashto,
# sindhi, yiddish, syriac, dhivehi, nko, adlam, mandaic, samaritan,
# dari, uyghur, balochi, kashmiri, shahmukhi, azeri-south, jawi,
# turoyo
# Default: english
RESPONSE_LANGUAGE=english

# =================================================================
# TERMINAL EMULATOR (macOS-only)
# =================================================================
# Options: wezterm  (auto-installed by the .pkg — RECOMMENDED; the only
#                    macOS terminal in our matrix that renders Hebrew
#                    correctly out of the box)
#          terminal (Apple Terminal — cannot do RTL paragraph alignment;
#                    BiDi wrapper helps with the bullet-line bug only)
#          iterm2   (iTerm2 — its BiDi is broken in 3.6.x; not recommended)
#
# See docs/TROUBLESHOOTING.md and kivun-terminal-rtl-debug.v2.md.
# Default: wezterm
MAC_TERMINAL=wezterm

# =================================================================
# TERMINAL COLOR THEME
# =================================================================
# Options: kivun   (light-blue Kivun theme via osascript)
#          default (keep your terminal's existing theme)
# Default: kivun
TERMINAL_COLOR=kivun

# =================================================================
# FOLDER PICKER ON LAUNCH
# =================================================================
# When true, the desktop shortcut pops a Finder folder-browse
# dialog before launching Claude Code.
# Default: true on macOS
FOLDER_PICKER=true

# =================================================================
# CLAUDE STARTUP FLAGS
# =================================================================
# Optional flags applied on every launch.
# Example: CLAUDE_FLAGS=--continue
CLAUDE_FLAGS=

# =================================================================
# BIDI WRAPPER (Hebrew rendering for Claude Code output)
# =================================================================
# The wrapper injects Unicode RLE/PDF bracket pairs around Hebrew
# runs and an RLM at line start. It exists for terminals that LACK
# native BiDi (Konsole on Linux, Apple Terminal on macOS).
#
# WezTerm has native BiDi — running the wrapper there causes
# double-application and Hebrew comes out mirrored. So when
# MAC_TERMINAL=wezterm (the default), the wrapper MUST be off.
#
# Set to "on" only if MAC_TERMINAL=terminal (Apple Terminal) AND
# you want the bullet-line RLM injection. RTL paragraph alignment
# is not achievable in Apple Terminal regardless.
# Default: off (because default MAC_TERMINAL is wezterm)
KIVUN_BIDI_WRAPPER=off

# =================================================================
# Not used on macOS: USE_VCXSRV (Windows/WSL only)
# =================================================================
CONFIG
    chown "$REAL_USER" "$CONFIG_FILE"
    log "Configuration file created at $CONFIG_FILE"
else
    # v1.2.2 migration: force the BiDi-correct combo (MAC_TERMINAL=wezterm,
    # KIVUN_BIDI_WRAPPER=off) regardless of existing values. v1.2.1 and
    # earlier shipped MAC_TERMINAL=terminal as default, which cannot do RTL
    # paragraph alignment; users who manually picked MAC_TERMINAL=iterm2
    # also ended up broken (iTerm2 3.6.x BiDi is unreliable). The only
    # config that produces correct Hebrew is wezterm + wrapper off.
    # Backup the user's existing config so any custom edits are recoverable.
    log "Migrating existing config to v1.2.2 BiDi-correct defaults"
    BACKUP="${CONFIG_FILE}.bak.pre-v1.2.2"
    if [ ! -f "$BACKUP" ]; then
        cp "$CONFIG_FILE" "$BACKUP"
        chown "$REAL_USER" "$BACKUP"
        log "  backed up prior config to $BACKUP"
    fi

    # Force-correct values for keys we know must be specific, regardless
    # of any prior user choice (the prior choices were all broken).
    set_canonical_value() {
        local key="$1"
        local target_value="$2"
        if grep -qE "^[[:space:]]*${key}=" "$CONFIG_FILE"; then
            awk -v k="$key" -v v="$target_value" '
                $0 ~ "^[[:space:]]*"k"=" { print k"="v; next }
                { print }
            ' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
            log "  forced ${key}=${target_value}"
        else
            { echo ""; echo "${key}=${target_value}"; } >> "$CONFIG_FILE"
            log "  appended ${key}=${target_value}"
        fi
    }
    set_canonical_value "MAC_TERMINAL" "wezterm"
    set_canonical_value "KIVUN_BIDI_WRAPPER" "off"

    # For keys that are user-preference (color/language/etc), only add if
    # missing — preserve existing user choices.
    add_missing_key() {
        local key="$1"
        local default_value="$2"
        if ! grep -qE "^[[:space:]]*${key}=" "$CONFIG_FILE"; then
            { echo ""; echo "${key}=${default_value}"; } >> "$CONFIG_FILE"
            log "  added missing ${key}=${default_value}"
        fi
    }
    add_missing_key "RESPONSE_LANGUAGE" "english"
    add_missing_key "TERMINAL_COLOR"    "kivun"
    add_missing_key "FOLDER_PICKER"     "true"
    add_missing_key "CLAUDE_FLAGS"      ""
    chown "$REAL_USER" "$CONFIG_FILE"
fi

# --- Desktop Shortcut with Folder Picker ---
log "Creating desktop shortcut..."
# Remove old-name shortcut from previous installs
rm -f "$REAL_HOME/Desktop/Kivun Terminal.command"
SHORTCUT_PATH="$REAL_HOME/Desktop/Kivun Terminal.command"
cat > "$SHORTCUT_PATH" << 'SCRIPT'
#!/bin/bash
# Kivun Terminal — launches Claude Code with folder picker

CONFIG_DIR="$HOME/Library/Application Support/Kivun-Terminal"
CONFIG_FILE="$CONFIG_DIR/config.txt"
STATUSLINE_DIR="/usr/local/share/kivun-terminal"

# Statusline
export CLAUDE_CODE_STATUSLINE="$STATUSLINE_DIR/statusline.mjs"

# Read configuration
RESPONSE_LANGUAGE="english"
TERMINAL_COLOR="kivun"
MAC_TERMINAL="wezterm"
FOLDER_PICKER="true"
CLAUDE_FLAGS=""
KIVUN_BIDI_WRAPPER="off"
# Pure-bash trim avoids xargs's glob expansion and quote stripping —
# a value like `*` or `?` must pass through unchanged.
trim() {
    local s="$1"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}
if [ -f "$CONFIG_FILE" ]; then
    # `|| [[ -n "$key" ]]` handles a missing trailing newline: without
    # it, a config file that doesn't end in \n drops its last key=value.
    while IFS='=' read -r key value || [[ -n "$key" ]]; do
        [[ "$key" =~ ^#.*$ ]] && continue
        [[ -z "$key" ]] && continue
        key=$(trim "$key")
        value=$(trim "$value")
        case "$key" in
            RESPONSE_LANGUAGE) RESPONSE_LANGUAGE="$value" ;;
            TERMINAL_COLOR) TERMINAL_COLOR="$value" ;;
            MAC_TERMINAL) MAC_TERMINAL="$value" ;;
            FOLDER_PICKER) FOLDER_PICKER="$value" ;;
            CLAUDE_FLAGS) CLAUDE_FLAGS="$value" ;;
            KIVUN_BIDI_WRAPPER) KIVUN_BIDI_WRAPPER="$value" ;;
        esac
    done < "$CONFIG_FILE"
fi

# Decide which binary to run. The BiDi wrapper helps only on terminals
# that LACK native BiDi (Apple Terminal). On WezTerm/iTerm2 it would
# double-apply marks and mirror Hebrew, so it must be skipped there even
# if the user manually flipped KIVUN_BIDI_WRAPPER=on.
CLAUDE_EXEC="claude"
if [ "$KIVUN_BIDI_WRAPPER" = "on" ] && [ "$MAC_TERMINAL" = "terminal" ]; then
    WRAPPER_BIN="/usr/local/share/kivun-terminal/kivun-claude-bidi/bin/kivun-claude-bidi"
    if [ -x "$WRAPPER_BIN" ]; then
        CLAUDE_EXEC="$WRAPPER_BIN"
    elif command -v kivun-claude-bidi >/dev/null 2>&1; then
        CLAUDE_EXEC="kivun-claude-bidi"
    fi
fi

# Apply Terminal.app color scheme only if this window is Terminal.app AND
# TERMINAL_COLOR=kivun. iTerm2 and WezTerm don't use osascript colors.
if [ "$TERMINAL_COLOR" = "kivun" ] && [ "$MAC_TERMINAL" = "terminal" ]; then
    osascript -e '
    tell application "Terminal"
        tell front window
            set background color of selected tab to {51400, 59110, 65535}
            set normal text color of selected tab to {0, 0, 0}
            set bold text color of selected tab to {0, 0, 0}
            set cursor color of selected tab to {6425, 6425, 6425}
        end tell
    end tell
    ' 2>/dev/null
fi

clear
echo "Kivun Terminal"
echo ""

# Folder selection order:
#   1. Explicit $1 from caller (Automator right-click, CLI invocation)
#   2. FOLDER_PICKER=true config → Finder folder-picker dialog
#   3. $HOME fallback
if [ $# -ge 1 ] && [ -d "$1" ]; then
    FOLDER="$1"
elif [ "$FOLDER_PICKER" = "true" ]; then
    FOLDER=$(osascript -e 'tell application "Finder"
        try
            set selectedFolder to choose folder with prompt "Select a folder to open with Claude Code:"
            return POSIX path of selectedFolder
        on error
            return ""
        end try
    end tell' 2>/dev/null)

    if [ -z "$FOLDER" ]; then
        echo "No folder selected. Exiting..."
        read -p "Press Enter to close..."
        exit 0
    fi
else
    FOLDER="$HOME"
fi

cd "$FOLDER" || exit 1

# Build language prompt argument. Shared map at
# /usr/local/share/kivun-terminal/languages.sh — one source of truth
# across Linux + macOS. Silent fallback to no-prompt if missing.
LANG_PROMPT=""
LANG_MAP="/usr/local/share/kivun-terminal/languages.sh"
if [ -f "$LANG_MAP" ]; then
    # shellcheck disable=SC1090
    . "$LANG_MAP"
    LANG_PROMPT=$(kivun_lang_prompt "$RESPONSE_LANGUAGE")
fi

echo "Starting Claude Code in: $FOLDER"
echo ""

# Respawn in iTerm2 / WezTerm if the user picked one of those in config.
# The .command file is always opened by Terminal.app on double-click; so
# if MAC_TERMINAL != terminal, we hand off to the chosen emulator with
# the same folder pre-selected, then exit this Terminal.app instance.
#
# SECURITY: folder names can contain single quotes (e.g. "O'Brien's docs"),
# dollar signs, backticks. Don't interpolate them into an AppleScript
# `write text` shell command blindly — escape single quotes by closing,
# inserting an escaped quote, re-opening: foo'bar → 'foo'\''bar'
shell_quote() {
    # $1 → single-quoted safe form for POSIX sh
    printf "'%s'" "${1//\'/\'\\\'\'}"
}
case "$MAC_TERMINAL" in
    iterm2)
        ITERM_CMD="cd $(shell_quote "$FOLDER") && $(shell_quote "$CLAUDE_EXEC")"
        [ -n "$LANG_PROMPT" ] && ITERM_CMD="$ITERM_CMD --append-system-prompt $(shell_quote "$LANG_PROMPT")"
        [ -n "$CLAUDE_FLAGS" ] && ITERM_CMD="$ITERM_CMD $CLAUDE_FLAGS"
        # Second escape layer: the AppleScript `write text "..."` string
        # itself must be a valid AppleScript literal. Replace " and \ inside.
        ITERM_CMD_AS="${ITERM_CMD//\\/\\\\}"
        ITERM_CMD_AS="${ITERM_CMD_AS//\"/\\\"}"
        osascript <<OSASCRIPT 2>/dev/null && exit 0
tell application "iTerm"
    activate
    create window with default profile
    tell current session of current window to write text "$ITERM_CMD_AS"
end tell
OSASCRIPT
        ;;
    wezterm)
        # WezTerm has native BiDi BUT ships with bidi_enabled=false. Our
        # bundled wezterm.lua at /usr/local/share/kivun-terminal/wezterm.lua
        # enables BiDi AND applies the Kivun light-blue theme. Loaded via
        # --config-file so the user's own ~/.config/wezterm/wezterm.lua is
        # left untouched and applies to non-Kivun WezTerm sessions.
        # The CLI ships alongside the .app via brew --cask wezterm; the
        # Apple Silicon brew prefix is /opt/homebrew, Intel is /usr/local.
        WEZTERM_BIN=""
        if command -v wezterm >/dev/null 2>&1; then
            WEZTERM_BIN="wezterm"
        elif [ -x "/opt/homebrew/bin/wezterm" ]; then
            WEZTERM_BIN="/opt/homebrew/bin/wezterm"
        elif [ -x "/usr/local/bin/wezterm" ]; then
            WEZTERM_BIN="/usr/local/bin/wezterm"
        elif [ -x "/Applications/WezTerm.app/Contents/MacOS/wezterm" ]; then
            WEZTERM_BIN="/Applications/WezTerm.app/Contents/MacOS/wezterm"
        fi
        if [ -n "$WEZTERM_BIN" ]; then
            WEZTERM_LUA="/usr/local/share/kivun-terminal/wezterm.lua"
            if [ -f "$WEZTERM_LUA" ]; then
                if [ -n "$LANG_PROMPT" ]; then
                    "$WEZTERM_BIN" --config-file "$WEZTERM_LUA" start --cwd "$FOLDER" -- "$CLAUDE_EXEC" --append-system-prompt "$LANG_PROMPT" $CLAUDE_FLAGS &
                else
                    "$WEZTERM_BIN" --config-file "$WEZTERM_LUA" start --cwd "$FOLDER" -- "$CLAUDE_EXEC" $CLAUDE_FLAGS &
                fi
            else
                # Bundled config missing (corrupt install?). Run anyway
                # so the user gets claude — Hebrew may render LTR until
                # they reinstall.
                if [ -n "$LANG_PROMPT" ]; then
                    "$WEZTERM_BIN" start --cwd "$FOLDER" -- "$CLAUDE_EXEC" --append-system-prompt "$LANG_PROMPT" $CLAUDE_FLAGS &
                else
                    "$WEZTERM_BIN" start --cwd "$FOLDER" -- "$CLAUDE_EXEC" $CLAUDE_FLAGS &
                fi
            fi
            disown 2>/dev/null || true
            exit 0
        fi
        # WezTerm not installed (postinstall should have done it, but the
        # brew install can fail on offline / restricted machines). Fall
        # through to the default Apple Terminal path so the user still
        # gets claude — RTL will be limited.
        echo "WARNING: WezTerm CLI not found; falling back to Apple Terminal."
        echo "  Recover with:  brew install --cask wezterm"
        echo ""
        ;;
esac

# Default: run claude directly in this Terminal.app window.
# SECURITY: no eval; pass flags as separate arguments.
# CLAUDE_EXEC is either `claude` or the absolute path to the BiDi wrapper
# binary (chosen above based on KIVUN_BIDI_WRAPPER and the wrapper's
# install state). Quote it to handle paths with spaces.
if [ -n "$LANG_PROMPT" ]; then
    if [ -n "$CLAUDE_FLAGS" ]; then
        "$CLAUDE_EXEC" --append-system-prompt "$LANG_PROMPT" $CLAUDE_FLAGS
    else
        "$CLAUDE_EXEC" --append-system-prompt "$LANG_PROMPT"
    fi
else
    if [ -n "$CLAUDE_FLAGS" ]; then
        "$CLAUDE_EXEC" $CLAUDE_FLAGS
    else
        "$CLAUDE_EXEC"
    fi
fi
SCRIPT
chmod +x "$SHORTCUT_PATH"
chown "$REAL_USER" "$SHORTCUT_PATH"
log "Desktop shortcut created at $SHORTCUT_PATH"

# --- Finder Quick Action (Right-Click Context Menu) ---
log "Creating Finder Quick Action..."
WORKFLOW_DIR="$REAL_HOME/Library/Services"
WORKFLOW_PATH="$WORKFLOW_DIR/Open with Kivun Terminal.workflow"
run_as_user "mkdir -p '$WORKFLOW_DIR'" 2>/dev/null || true

# Remove old workflow if it exists
rm -rf "$WORKFLOW_PATH" 2>/dev/null || true

# Create Automator workflow directory structure
mkdir -p "$WORKFLOW_PATH/Contents"
cat > "$WORKFLOW_PATH/Contents/Info.plist" << 'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>NSServices</key>
    <array>
        <dict>
            <key>NSMenuItem</key>
            <dict>
                <key>default</key>
                <string>Open with Kivun Terminal</string>
            </dict>
            <key>NSMessage</key>
            <string>runWorkflowAsService</string>
            <key>NSRequiredContext</key>
            <dict>
                <key>NSApplicationIdentifier</key>
                <string>com.apple.finder</string>
            </dict>
            <key>NSSendFileTypes</key>
            <array>
                <string>public.folder</string>
            </array>
        </dict>
    </array>
    <key>CFBundleIdentifier</key>
    <string>com.noambrand.kivun-terminal.quickaction</string>
    <key>CFBundleName</key>
    <string>Open with Kivun Terminal</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
</dict>
</plist>
PLIST

mkdir -p "$WORKFLOW_PATH/Contents/QuickLook"
cat > "$WORKFLOW_PATH/Contents/document.wflow" << 'WFLOW'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
