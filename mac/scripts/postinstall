                <dict>
                    <key>COMMAND_STRING</key>
                    <string>#!/bin/bash
# Automator Quick Action: right-click a folder in Finder → "Open with
# Kivun Terminal". All logic (config parsing, language prompts, terminal
# respawn, color scheme) lives in the desktop .command file — this
# action is a 20-line dispatcher that forwards the selected folder as
# arg 1. Single source of truth eliminates the case where the Quick
# Action's language list drifted from the documented one.
FOLDER="$1"
SHORTCUT="$HOME/Desktop/Kivun Terminal.command"
if [ ! -x "$SHORTCUT" ]; then
    osascript -e 'display alert "Kivun Terminal not found" message "The Kivun Terminal launcher is missing. Reinstall the .pkg from the latest release."'
    exit 1
fi
# printf %q produces shell-safe quoting (bash/zsh both understand). Used
# inside AppleScript `do script`, which types the command into a new
# Terminal tab as if the user typed it — so the user's login shell (zsh
# on modern macOS) parses it. This defuses folder names like
# "O'Brien" or "$(rm -rf ~)".
Q_SHORTCUT=$(printf '%q' "$SHORTCUT")
Q_FOLDER=$(printf '%q' "$FOLDER")
CMD="$Q_SHORTCUT $Q_FOLDER"
# Second escape: AppleScript string literal level. Backslashes and
# double-quotes must be escaped to survive the AppleScript parser.
CMD_AS="${CMD//\\/\\\\}"
CMD_AS="${CMD_AS//\"/\\\"}"
osascript &lt;&lt;OSASCRIPT
tell application "Terminal"
    activate
    do script "$CMD_AS"
end tell
OSASCRIPT
</string>
                    <key>CheckedForUserDefaultShell</key>
                    <true/>
                    <key>inputMethod</key>
                    <integer>1</integer>
                    <key>shell</key>
                    <string>/bin/bash</string>
                    <key>source</key>
                    <string></string>
                </dict>
                <key>BundleIdentifier</key>
                <string>com.apple.RunShellScript</string>
                <key>CFBundleVersion</key>
                <string>1.0</string>
                <key>CanShowSelectedItemsWhenRun</key>
                <false/>
                <key>CanShowWhenRun</key>
                <true/>
                <key>Category</key>
                <array>
                    <string>AMCategoryUtilities</string>
                </array>
                <key>Class Name</key>
                <string>RunShellScriptAction</string>
                <key>InputUUID</key>
                <string>00000000-0000-0000-0000-000000000000</string>
