<!DOCTYPE html>
<!--
  Kivun Terminal - Folder Picker (HTA dialog)

  v1.4.0 adds an inline Claude-flags picker — model selector,
  conversation-continuation radios, skip-permissions checkbox,
  free-text custom flags. Reads and writes back to
  config.txt's CLAUDE_FLAGS line so the user never has to open
  config.txt to manage Claude flags.

  Same writeback contract as before: on OK with a valid folder,
  writes the chosen path to %LOCALAPPDATA%\Kivun-WSL\kivun-workdir.txt
  as UTF-8 without BOM AND updates config.txt's CLAUDE_FLAGS line.
  On Cancel, neither file is touched - launcher treats missing
  workdir.txt as cancellation.

  Run with: mshta.exe folder-picker.hta
-->
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>Kivun Terminal - Pick Folder</title>
<HTA:APPLICATION
  ID="KivunPicker"
  APPLICATIONNAME="Kivun Terminal Folder Picker"
  BORDER="dialog"
  CAPTION="yes"
  CONTEXTMENU="no"
  INNERBORDER="no"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SCROLL="auto"
  SELECTION="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  SYSMENU="yes"
  WINDOWSTATE="normal"
/>
<style>
  html, body { height: 100%; }
  body {
    font-family: "Segoe UI", "Segoe UI Variable", Arial, sans-serif;
    font-size: 17px;
    margin: 0;
    padding: 22px 36px;
    background: #f3f3f3;
    color: #1c1c1c;
    box-sizing: border-box;
  }
  h1 {
    font-size: 23px;
    font-weight: 600;
    margin: 0 0 10px 0;
    color: #1c1c1c;
  }
  .hint {
    font-size: 15px;
    color: #404040;
    margin: 0 0 18px 0;
    line-height: 1.5;
  }
  .hint code, .hint kbd {
    font-family: "Consolas", "Cascadia Mono", monospace;
    font-size: 14px;
    background: #e8e8e8;
    padding: 2px 7px;
    border-radius: 3px;
  }

  .option {
    background: #fff;
    border: 1px solid #d4d4d4;
    border-radius: 6px;
    padding: 16px 20px;
    margin-bottom: 4px;
  }
  .opt-label {
    font-size: 16px;
    font-weight: 600;
    color: #1c1c1c;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .opt-num {
    display: inline-block;
    width: 26px;
    height: 26px;
    line-height: 26px;
    text-align: center;
    background: #0078d4;
    color: #fff;
    border-radius: 50%;
    font-size: 14px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .or-sep {
    text-align: center;
    margin: 10px 0;
    position: relative;
  }
  .or-sep:before {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    border-top: 1px solid #cfcfcf;
    z-index: 0;
  }
  .or-sep span {
    position: relative;
    display: inline-block;
    padding: 0 16px;
    background: #f3f3f3;
    color: #606060;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    z-index: 1;
  }

  input[type=text] {
    width: 100%;
    box-sizing: border-box;
    padding: 12px 15px;
    font-family: "Consolas", "Cascadia Mono", "Segoe UI", monospace;
    font-size: 17px;
    border: 1px solid #b8b8b8;
    background: #fff;
    border-radius: 4px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  input[type=text]:focus {
    outline: none;
    border-color: #0078d4;
    box-shadow: 0 0 0 1px #0078d4;
  }
  button {
    padding: 10px 18px;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 15px;
    background: #fafafa;
    border: 1px solid #b8b8b8;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 4px;
    transition: background 0.15s, border-color 0.15s;
  }
  button:hover { background: #eaeaea; border-color: #888; }
  button:active { background: #d8d8d8; }
  button.primary {
    background: #0078d4;
    color: #fff;
    border-color: #005a9e;
    font-weight: 600;
  }
  button.primary:hover { background: #1186e0; border-color: #00467a; }
  button.primary:active { background: #005a9e; }
  button.browse { min-width: 230px; font-weight: 600; }
  button.config { min-width: 180px; font-size: 13px; }
  button.cancel { min-width: 110px; }
  button.ok { min-width: 250px; font-size: 16px; }

  /* Flag picker */
  .flag-grid {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 10px 14px;
    align-items: center;
    margin-top: 4px;
  }
  .flag-grid > .lbl {
    font-weight: 600;
    color: #303030;
    font-size: 14px;
    text-align: right;
  }
  .flag-grid select {
    padding: 7px 10px;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 14px;
    border: 1px solid #b8b8b8;
    background: #fff;
    border-radius: 4px;
    width: 100%;
    box-sizing: border-box;
  }
  .flag-grid select:focus {
    outline: none;
    border-color: #0078d4;
    box-shadow: 0 0 0 1px #0078d4;
  }
  .radio-row, .check-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    font-size: 14px;
    color: #303030;
  }
  .radio-row label, .check-row label {
    cursor: pointer;
    user-select: none;
  }
  .radio-row input, .check-row input {
    margin-right: 6px;
    vertical-align: middle;
  }
  .flag-grid input[type=text] {
    padding: 8px 12px;
    font-size: 14px;
  }
  .flag-help {
    font-size: 12px;
    color: #707070;
    margin-top: 2px;
  }
  .flag-preview {
    margin-top: 12px;
    padding: 9px 12px;
    background: #f7f7f7;
    border: 1px solid #d4d4d4;
    border-radius: 4px;
    font-family: "Consolas", "Cascadia Mono", monospace;
    font-size: 13px;
    color: #1c1c1c;
    word-break: break-all;
  }
  .flag-preview .label {
    color: #707070;
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 12px;
    margin-right: 8px;
  }

  .actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid #d8d8d8;
  }
  .actions .right { display: flex; gap: 10px; }
  .err {
    color: #b00020;
    font-size: 14px;
    min-height: 18px;
    margin: 8px 0 0 0;
    font-weight: 500;
  }
</style>
<script language="JScript">
  // 1000x860 fits the new flag picker section. Earlier window sizes:
  // 1000x620 (v1.3.3-1.3.5), 920x520 (v1.3.2), 880x340 (v1.3.1).
  window.resizeTo(1000, 860);

  var wshShell = new ActiveXObject("WScript.Shell");
  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var shell = new ActiveXObject("Shell.Application");

  function getInstallDir() {
    var url = decodeURIComponent(location.pathname).replace(/^\//, "").replace(/\//g, "\\");
    return fso.GetParentFolderName(url);
  }

  var installDir = getInstallDir();
  var kivunDir = wshShell.ExpandEnvironmentStrings("%LOCALAPPDATA%") + "\\Kivun-WSL";
  var resultFile = kivunDir + "\\kivun-workdir.txt";
  var configFile = installDir + "\\config.txt";

  if (!fso.FolderExists(kivunDir)) {
    fso.CreateFolder(kivunDir);
  }

  // UTF-8 without BOM. Same code as the original: write text via ADODB
  // stream, then strip the 3-byte BOM by reading from offset 3.
  function writeUtf8NoBom(path, content) {
    var stream = new ActiveXObject("ADODB.Stream");
    stream.Type = 2;
    stream.Charset = "utf-8";
    stream.Open();
    stream.WriteText(content);
    stream.Position = 0;
    stream.Type = 1;
    stream.Position = 3;
    var outStream = new ActiveXObject("ADODB.Stream");
    outStream.Type = 1;
    outStream.Open();
    stream.CopyTo(outStream);
    outStream.SaveToFile(path, 2);
    outStream.Close();
    stream.Close();
  }

  function readUtf8(path) {
    if (!fso.FileExists(path)) return "";
    var stream = new ActiveXObject("ADODB.Stream");
    stream.Type = 2;
    stream.Charset = "utf-8";
    stream.Open();
    stream.LoadFromFile(path);
    var text = stream.ReadText();
    stream.Close();
    return text;
  }

  function writePath(p) {
    writeUtf8NoBom(resultFile, p);
  }

  function clearError() { document.getElementById("err").innerText = ""; }
  function showError(msg) { document.getElementById("err").innerText = msg; }

  function browseFolder() {
    clearError();
    var startPath = wshShell.ExpandEnvironmentStrings("%USERPROFILE%");
    // BIF_NEWDIALOGSTYLE | BIF_EDITBOX = 0x50.
    var folder = shell.BrowseForFolder(0, "Pick a folder", 0x50, startPath);
    if (folder != null) {
      document.getElementById("path").value = folder.Self.Path;
      document.getElementById("path").focus();
    }
  }

  function editConfig() {
    clearError();
    if (!fso.FileExists(configFile)) {
      showError("config.txt not found at " + configFile);
      return;
    }
    wshShell.Run("notepad.exe \"" + configFile + "\"", 1, false);
  }

  // ---- Flag picker ---------------------------------------------------

  function getRadioValue(name) {
    var radios = document.getElementsByName(name);
    for (var i = 0; i < radios.length; i++) {
      if (radios[i].checked) return radios[i].value;
    }
    return "";
  }
  function setRadioValue(name, value) {
    var radios = document.getElementsByName(name);
    for (var i = 0; i < radios.length; i++) {
      if (radios[i].value == value) { radios[i].checked = true; return; }
    }
    if (radios.length) radios[0].checked = true;
  }

  function composeFlags() {
    var parts = [];
    var model = document.getElementById("flag-model").value;
    if (model) parts.push("--model " + model);
    var conv = getRadioValue("flag-conv");
    if (conv) parts.push(conv);
    if (document.getElementById("flag-skip-perm").checked) {
      parts.push("--dangerously-skip-permissions");
    }
    var custom = document.getElementById("flag-custom").value;
    custom = custom.replace(/^\s+|\s+$/g, "");
    if (custom) parts.push(custom);
    return parts.join(" ");
  }

  function updateFlagPreview() {
    var s = composeFlags();
    document.getElementById("flag-effective").innerText = s ? s : "(none — default Claude behavior)";
  }

  // Read CLAUDE_FLAGS=... line from config.txt and split it across
  // the dropdown / radios / checkbox / custom field.
  function loadFlagsFromConfig() {
    var content = readUtf8(configFile);
    var match = content.match(/^CLAUDE_FLAGS=(.*)$/m);
    var current = match ? match[1].replace(/^\s+|\s+$/g, "") : "";
    if (!current) { updateFlagPreview(); return; }

    // --model X
    var m = current.match(/--model\s+(\S+)/);
    if (m) {
      var modelEl = document.getElementById("flag-model");
      for (var i = 0; i < modelEl.options.length; i++) {
        if (modelEl.options[i].value == m[1]) { modelEl.selectedIndex = i; break; }
      }
      current = current.replace(m[0], "");
    }

    // --continue / --resume (mutually exclusive)
    if (/(^|\s)--continue(\s|$)/.test(current)) {
      setRadioValue("flag-conv", "--continue");
      current = current.replace(/--continue/g, "");
    } else if (/(^|\s)--resume(\s|$)/.test(current)) {
      setRadioValue("flag-conv", "--resume");
      current = current.replace(/--resume/g, "");
    } else {
      setRadioValue("flag-conv", "");
    }

    // --dangerously-skip-permissions
    if (/(^|\s)--dangerously-skip-permissions(\s|$)/.test(current)) {
      document.getElementById("flag-skip-perm").checked = true;
      current = current.replace(/--dangerously-skip-permissions/g, "");
    }

    // Whatever's left becomes the custom field
    current = current.replace(/\s+/g, " ").replace(/^\s+|\s+$/g, "");
    document.getElementById("flag-custom").value = current;

    updateFlagPreview();
  }

  // Replace the CLAUDE_FLAGS line in config.txt with our new value,
  // preserve all other lines + comments. If the key is missing, append.
  function writeFlagsToConfig(newFlags) {
    var content = readUtf8(configFile);
    if (!content) return;   // no config — nothing to write
    if (/^CLAUDE_FLAGS=.*$/m.test(content)) {
      content = content.replace(/^CLAUDE_FLAGS=.*$/m, "CLAUDE_FLAGS=" + newFlags);
    } else {
      // Append; keep CRLF style consistent with the rest of the file.
      var nl = (content.indexOf("\r\n") >= 0) ? "\r\n" : "\n";
      if (content.length && content.charAt(content.length - 1) !== "\n") content += nl;
      content += "CLAUDE_FLAGS=" + newFlags + nl;
    }
    writeUtf8NoBom(configFile, content);
  }

  function ok() {
    clearError();
    var p = document.getElementById("path").value;
    if (p == null) p = "";
    p = p.replace(/^\s+|\s+$/g, "");      // trim
    p = p.replace(/^"+|"+$/g, "");        // strip surrounding quotes
    if (p == "") {
      showError("Enter a folder path or click Browse.");
      document.getElementById("path").focus();
      return;
    }
    if (!fso.FolderExists(p)) {
      showError("Folder does not exist: " + p);
      document.getElementById("path").focus();
      return;
    }
    // Persist the chosen flags to config.txt before launching, so the
    // .bat reads them via the existing CLAUDE_FLAGS= parser.
    try { writeFlagsToConfig(composeFlags()); } catch (e) { /* non-fatal */ }
    writePath(p);
    window.close();
  }

  function cancel() { window.close(); }

  function onKey(ev) {
    var e = ev || window.event;
    var k = e.keyCode;
    if (k == 13) { ok(); return false; }
    if (k == 27) { cancel(); return false; }
    return true;
  }

  function init() {
    loadFlagsFromConfig();
    document.getElementById("path").focus();
  }
</script>
</head>
<body onload="init()">
  <h1>Pick a folder for Kivun Terminal</h1>
  <p class="hint">
    Choose <b>one</b> of the two options below, optionally tune the Claude flags, then click <b>Launch Kivun Terminal</b> (or press <kbd>Enter</kbd>).
  </p>

  <div class="option">
    <div class="opt-label"><span class="opt-num">1</span> Type or paste a Windows path:</div>
    <input type="text" id="path" onkeydown="return onKey(event)" placeholder="C:\Users\you\Documents\MyProject" />
  </div>

  <div class="or-sep"><span>OR</span></div>

  <div class="option">
    <div class="opt-label"><span class="opt-num">2</span> Pick a folder from the Windows folder tree:</div>
    <button class="browse" onclick="browseFolder()">Browse Folder Tree...</button>
  </div>

  <div class="option" style="margin-top:14px">
    <div class="opt-label"><span class="opt-num">3</span> Claude flags (optional):</div>
    <div class="flag-grid">
      <div class="lbl">Model:</div>
      <div>
        <select id="flag-model" onchange="updateFlagPreview()">
          <option value="">Default (let Claude decide)</option>
          <option value="opus">Opus - most capable, slower / more expensive</option>
          <option value="sonnet">Sonnet - balanced speed and capability</option>
          <option value="haiku">Haiku - fastest, cheapest</option>
        </select>
      </div>

      <div class="lbl">Conversation:</div>
      <div class="radio-row">
        <label><input type="radio" name="flag-conv" value="" onclick="updateFlagPreview()" checked /> Start fresh</label>
        <label><input type="radio" name="flag-conv" value="--continue" onclick="updateFlagPreview()" /> Continue last (--continue)</label>
        <label><input type="radio" name="flag-conv" value="--resume" onclick="updateFlagPreview()" /> Pick from history (--resume)</label>
      </div>

      <div class="lbl">Permissions:</div>
      <div class="check-row">
        <label><input type="checkbox" id="flag-skip-perm" onclick="updateFlagPreview()" /> Skip permission prompts (--dangerously-skip-permissions)</label>
      </div>

      <div class="lbl">Custom:</div>
      <div>
        <input type="text" id="flag-custom" onkeyup="updateFlagPreview()" placeholder="--append-system-prompt &quot;respond in Hebrew&quot;  --any-other-flag value" />
        <div class="flag-help">Anything you type here is appended verbatim to the Claude command.</div>
      </div>
    </div>
    <div class="flag-preview"><span class="label">Effective:</span><span id="flag-effective">(none)</span></div>
  </div>

  <div class="actions">
    <button class="config" onclick="editConfig()" title="Open config.txt in Notepad for advanced settings (language, theme, BiDi tunables)">Open config.txt (advanced)</button>
    <div class="right">
      <button class="cancel" onclick="cancel()">Cancel</button>
      <button class="primary ok" onclick="ok()">Launch Kivun Terminal</button>
    </div>
  </div>
  <p class="err" id="err"></p>
</body>
</html>
